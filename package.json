{
  "name": "trivivia",
  "version": "1.0.0",
  "description": "",
  "main": "start.sh",
  "scripts": {
    "start": "yarn start:dev",
    "start:dev": "concurrently -n srv,client \"yarn start:server\" \"yarn start:client\"",
    "start:client": "cd client && yarn start",
    "start:server": "cd server && yarn start",
    "install-playwright": "yarn --cwd integration playwright install chromium",
    "test:integration": "yarn --cwd integration test:prod",
    "build": "(cd client && yarn build)",
    "lint": "eslint ."
  },
  "author": "",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared",
    "integration"
  ],
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "sqlite3": {
      "built": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "concurrently": "^7.6.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-react": "^7.37.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.0",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.9",
    "vitest-github-actions-reporter": "^0.10.0"
  },
  "packageManager": "yarn@4.17.0"
}
