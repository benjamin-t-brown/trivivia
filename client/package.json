{
  "name": "trivivia-client",
  "version": "1.0.1",
  "description": "Client code for Trivivia",
  "main": "src/index.html",
  "scripts": {
    "test": "vitest --coverage",
    "test:prod": "vitest run",
    "start": "vite serve src --config ./vite.config.ts",
    "start:dev": "yarn start",
    "build": "vite build src --config ./vite.config.ts --emptyOutDir",
    "clean": "node -e \"require('fs').rmSync('../dist/release',{recursive:true,force:true})\""
  },
